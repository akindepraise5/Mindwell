# Copy this file to .env and fill in your values
PORT=5000

# Use a long, random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_this_secret

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mindwell

# Optional: comma-separated list of allowed frontend origins for CORS.
# Defaults to "*" when not set.
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000
